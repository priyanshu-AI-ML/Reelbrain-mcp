# ─── Gemini Flash (required for analysis) ─────────────────────────────────────
# Get free key at: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Instagram Bot Account (required for DM watcher) ──────────────────────────
# Create a SEPARATE Instagram account to use as the bot (not your main account)
IG_BOT_USERNAME=your_bot_instagram_username
IG_BOT_PASSWORD=your_bot_instagram_password

# ─── Optional settings ────────────────────────────────────────────────────────
# How often to poll DMs in seconds (default: 600 = 10 minutes)
POLL_INTERVAL_SECONDS=600

# Whisper model size: tiny | small | medium (small = good balance; tiny = fastest)
WHISPER_MODEL=small

# Where SQLite + ChromaDB store data (Railway volume mounts here)
DATA_DIR=/data
